<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Material 3 semantic palette -->
    <Color x:Key="Primary">#6750A4</Color>
    <Color x:Key="OnPrimary">#FFFFFF</Color>
    <Color x:Key="PrimaryContainer">#EADDFF</Color>
    <Color x:Key="OnPrimaryContainer">#21005D</Color>

    <Color x:Key="PrimaryDark">#D0BCFF</Color>
    <Color x:Key="OnPrimaryDark">#381E72</Color>
    <Color x:Key="PrimaryContainerDark">#4F378B</Color>
    <Color x:Key="OnPrimaryContainerDark">#EADDFF</Color>

    <Color x:Key="Secondary">#625B71</Color>
    <Color x:Key="OnSecondary">#FFFFFF</Color>
    <Color x:Key="SecondaryContainer">#E8DEF8</Color>
    <Color x:Key="OnSecondaryContainer">#1D192B</Color>

    <Color x:Key="SecondaryDark">#CCC2DC</Color>
    <Color x:Key="OnSecondaryDark">#332D41</Color>
    <Color x:Key="SecondaryContainerDark">#4A4458</Color>
    <Color x:Key="OnSecondaryContainerDark">#E8DEF8</Color>

    <Color x:Key="Tertiary">#7D5260</Color>
    <Color x:Key="OnTertiary">#FFFFFF</Color>
    <Color x:Key="TertiaryContainer">#FFD8E4</Color>
    <Color x:Key="OnTertiaryContainer">#31111D</Color>

    <Color x:Key="TertiaryDark">#EFB8C8</Color>
    <Color x:Key="OnTertiaryDark">#492532</Color>
    <Color x:Key="TertiaryContainerDark">#633B48</Color>
    <Color x:Key="OnTertiaryContainerDark">#FFD8E4</Color>

    <Color x:Key="SurfaceLight">#FFFBFE</Color>
    <Color x:Key="SurfaceContainerLight">#F3EDF7</Color>
    <Color x:Key="SurfaceVariantLight">#E7E0EC</Color>
    <Color x:Key="OnSurfaceLight">#1D1B20</Color>
    <Color x:Key="OnSurfaceVariantLight">#49454F</Color>
    <Color x:Key="OutlineLight">#79747E</Color>
    <Color x:Key="OutlineVariantLight">#CAC4D0</Color>

    <Color x:Key="SurfaceDark">#141218</Color>
    <Color x:Key="SurfaceContainerDark">#211F26</Color>
    <Color x:Key="SurfaceVariantDark">#49454F</Color>
    <Color x:Key="OnSurfaceDark">#E6E1E5</Color>
    <Color x:Key="OnSurfaceVariantDark">#CAC4D0</Color>
    <Color x:Key="OutlineDark">#938F99</Color>
    <Color x:Key="OutlineVariantDark">#49454F</Color>

    <!-- Backwards-compatible aliases -->
    <Color x:Key="PrimaryDarkText">#381E72</Color>
    <Color x:Key="SecondaryDarkText">#E6E1E5</Color>

    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Magenta">#6750A4</Color>
    <Color x:Key="MidnightBlue">#1D1B20</Color>
    <Color x:Key="OffBlack">#141218</Color>

    <Color x:Key="Gray100">#F3EDF7</Color>
    <Color x:Key="Gray200">#E7E0EC</Color>
    <Color x:Key="Gray300">#CAC4D0</Color>
    <Color x:Key="Gray400">#938F99</Color>
    <Color x:Key="Gray500">#79747E</Color>
    <Color x:Key="Gray600">#625B71</Color>
    <Color x:Key="Gray900">#1D1B20</Color>
    <Color x:Key="Gray950">#141218</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="SurfaceLightBrush" Color="{StaticResource SurfaceLight}"/>
    <SolidColorBrush x:Key="SurfaceDarkBrush" Color="{StaticResource SurfaceDark}"/>
    <SolidColorBrush x:Key="SurfaceContainerLightBrush" Color="{StaticResource SurfaceContainerLight}"/>
    <SolidColorBrush x:Key="SurfaceContainerDarkBrush" Color="{StaticResource SurfaceContainerDark}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>