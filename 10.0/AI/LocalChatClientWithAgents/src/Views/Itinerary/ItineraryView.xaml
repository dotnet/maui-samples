<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="LocalChatClientWithAgents.Views.Itinerary.ItineraryView"
    x:DataType="ItineraryPageViewModel">

    <VerticalStackLayout Padding="20" Spacing="20">
        <VerticalStackLayout Spacing="10">
            <Label Text="{Binding Itinerary.Title}" FontSize="32" FontAttributes="Bold" />
            <Label Text="{Binding Itinerary.Description}" FontSize="16"
                   TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
        </VerticalStackLayout>
        
        <Border Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0"
                Background="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray900}}">
            <Grid ColumnSpacing="10" ColumnDefinitions="Auto, *">
                <Label Text="✨" FontSize="20" VerticalOptions="Start" />
                <Label
                    Text="{Binding Itinerary.Rationale}" FontSize="14" LineBreakMode="WordWrap" Grid.Column="1"
                    TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}" />
            </Grid>
        </Border>
        
        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Itinerary.Days}" Spacing="20">
            <BindableLayout.ItemTemplate>
                <DataTemplate x:DataType="DayPlanViewModel">
                    <DayView />
                </DataTemplate>
            </BindableLayout.ItemTemplate>
        </VerticalStackLayout>
    </VerticalStackLayout>

</ContentView>
