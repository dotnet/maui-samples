<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:LocalChatClientWithAgents.ViewModels"
    xmlns:views="clr-namespace:LocalChatClientWithAgents.Views.Itinerary"
    x:Class="LocalChatClientWithAgents.Pages.TripPlanningPage"
    x:DataType="viewModels:TripPlanningViewModel"
    SafeAreaEdges="None"
    Title="{Binding Landmark.Name}">

    <Grid SafeAreaEdges="None">

        <!-- Background Header Image -->
        <Image
            VerticalOptions="Start" HeightRequest="420" Aspect="AspectFill"
            Source="{Binding Landmark.BackgroundImageName, StringFormat='Images/Backgrounds/{0}.jpg'}" />

        <!-- Gradient overlay -->
        <BoxView VerticalOptions="Start" HeightRequest="420">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="{AppThemeBinding Light=#00FFFFFF, Dark=#001C1C1E}" Offset="0.3" />
                    <GradientStop Color="{AppThemeBinding Light=White, Dark=#1C1C1E}" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <!-- Main Content -->
        <ScrollView>
            <VerticalStackLayout Spacing="20" Padding="0,180,0,20">
                <views:LandmarkDescriptionView />
            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom panel: Trip configuration card -->
        <Border
            VerticalOptions="End"
            HorizontalOptions="Fill"
            MaximumWidthRequest="400"
            Margin="20,0,20,16"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 24"
            Background="{AppThemeBinding Light=#F2F5F5F7, Dark=#F21C1C1E}">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.15" Offset="0,-4" Radius="16" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="18" Padding="20,24,20,28">

                <!-- Duration -->
                <Grid RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="DURATION" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                    <Grid Grid.Row="1" ColumnDefinitions="48,*,48" ColumnSpacing="12">
                        <Button Text="−"
                                Command="{Binding DecrementDaysCommand}"
                                HeightRequest="48" WidthRequest="48"
                                CornerRadius="12" Padding="0"
                                FontSize="22" FontAttributes="Bold"
                                Background="{AppThemeBinding Light=White, Dark=#2C2C2E}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}"
                                BorderWidth="1"
                                BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                        <Label Grid.Column="1"
                               Text="{Binding DayCount, StringFormat='{0} days'}"
                               FontSize="22" FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />

                        <Button Grid.Column="2" Text="+"
                                Command="{Binding IncrementDaysCommand}"
                                HeightRequest="48" WidthRequest="48"
                                CornerRadius="12" Padding="0"
                                FontSize="22" FontAttributes="Bold"
                                Background="{AppThemeBinding Light=White, Dark=#2C2C2E}"
                                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}"
                                BorderWidth="1"
                                BorderColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
                    </Grid>
                </Grid>

                <!-- Language -->
                <Grid Grid.Row="1" RowDefinitions="Auto,Auto" RowSpacing="10">
                    <Label Text="LANGUAGE" FontSize="11" FontAttributes="Bold"
                           CharacterSpacing="1"
                           TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray300}}" />
                    <Border Grid.Row="1"
                            StrokeShape="RoundRectangle 12"
                            StrokeThickness="1"
                            Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            Background="{AppThemeBinding Light=White, Dark=#2C2C2E}"
                            Padding="14,0,10,0"
                            HeightRequest="48">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                            <Label Text="🌐" FontSize="18" VerticalOptions="Center" />
                            <Picker Grid.Column="1"
                                    ItemsSource="{Binding AvailableLanguages}"
                                    SelectedItem="{Binding SelectedLanguage}"
                                    FontSize="16"
                                    VerticalOptions="Center" />
                        </Grid>
                    </Border>
                </Grid>

                <!-- Generate button (full-width CTA) -->
                <Button Grid.Row="2"
                        Text="✨ Generate Itinerary"
                        Clicked="OnGenerateClicked"
                        FontSize="18" FontAttributes="Bold"
                        Padding="0,18" CornerRadius="14"
                        Margin="0,4,0,0"
                        HorizontalOptions="Fill"
                        Background="{StaticResource PrimaryBrush}"
                        TextColor="White">
                    <Button.Shadow>
                        <Shadow Brush="Black" Opacity="0.2" Offset="0,4" Radius="8" />
                    </Button.Shadow>
                </Button>

            </Grid>
        </Border>

        <!-- Floating Back Button (top left, pushed below status bar) -->
        <Grid VerticalOptions="Start" HorizontalOptions="Start" SafeAreaEdges="Container">
            <Button
                Text="←" Clicked="OnBackButtonClicked"
                Margin="20,20,0,0"
                HeightRequest="44" WidthRequest="44" CornerRadius="22" Padding="0"
                FontSize="24" Background="{AppThemeBinding Light=#80FFFFFF, Dark=#80000000}"
                TextColor="{AppThemeBinding Light={StaticResource Gray900}, Dark=White}" />
        </Grid>

    </Grid>

</ContentPage>
